{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; exec node \"$root/.anamnesis/codex-native-hooks/session-start.mjs\"'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; exec node \"$root/.anamnesis/codex-native-hooks/base-PostToolUse-Edit-remind-uncommitted.mjs\"'",
            "statusMessage": "Running anamnesis PostToolUse hook"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "sh -lc 'root=\"$(git rev-parse --show-toplevel 2>/dev/null || pwd)\"; exec node \"$root/.anamnesis/codex-native-hooks/base-Stop-handoff-reminder.mjs\"'",
            "statusMessage": "Running anamnesis Stop hook"
          }
        ]
      }
    ]
  }
}
