{
  "name": "@mcprotein/anamnesis",
  "version": "1.5.0",
  "description": "AI coding agent config lifecycle manager — keeps your agents from forgetting your project",
  "keywords": [
    "claude-code",
    "codex",
    "cursor",
    "agents",
    "ai-coding",
    "ontology",
    "scaffold",
    "lifecycle"
  ],
  "homepage": "https://github.com/MCprotein/anamnesis",
  "bugs": "https://github.com/MCprotein/anamnesis/issues",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MCprotein/anamnesis.git"
  },
  "license": "MIT",
  "author": "MCProtein",
  "type": "module",
  "exports": {
    ".": {
      "types": "./cli/dist/api.d.ts",
      "import": "./cli/dist/api.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "bin": {
    "anamnesis": "cli/dist/index.js"
  },
  "files": [
    "cli/dist",
    "base",
    "fragments",
    "capabilities",
    "docs",
    "rulebook.md",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p cli/tsconfig.json",
    "dev": "tsc -p cli/tsconfig.json --watch",
    "benchmark:gallery": "tsx cli/src/index.ts benchmark gallery --write",
    "benchmark:gallery:check": "tsx cli/src/index.ts benchmark gallery --validate",
    "benchmark:prompt-gate": "tsx cli/src/index.ts benchmark prompt-gate",
    "dogfood": "tsx cli/src/index.ts dogfood check --append",
    "dogfood:check": "tsx cli/src/index.ts dogfood check",
    "doctor:check": "tsx cli/src/index.ts doctor",
    "release:check": "npm run dogfood:check && npm run doctor:check && npm run benchmark:gallery:check && npm run benchmark:prompt-gate && npm run build",
    "typecheck": "tsc -p cli/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "echo \"no linter yet\" && exit 0",
    "clean": "rm -rf cli/dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  }
}
